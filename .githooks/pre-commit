#!/bin/sh
# Committed git hooks — enable once per clone with: make hooks
# Layering: pre-commit holds only near-instant checks (<1s). CI is the
# authority; these exist to kill the push -> red -> fix -> push round-trip.
set -eu

# --- Identity guard -----------------------------------------------------
# Commits must be authored AND committed with a GitHub noreply address, so
# no personal email ever lands in public commit metadata. That class of leak
# is unscrubbable once pushed (GH Archive records push events verbatim).
for ident in "$(git var GIT_AUTHOR_IDENT)" "$(git var GIT_COMMITTER_IDENT)"; do
  case "$ident" in
    *"@users.noreply.github.com>"*) ;;
    *)
      echo "pre-commit: identity is not a GitHub noreply address:" >&2
      echo "  $ident" >&2
      echo "fix: git config user.email '<id>+<login>@users.noreply.github.com'" >&2
      exit 1
      ;;
  esac
done

# --- gofmt on staged Go files -------------------------------------------
# Checks the worktree version of staged files: close enough for a fast gate,
# and the CI format job remains the exact authority.
gofmt_output=$(mktemp "${TMPDIR:-/tmp}/zotio-gofmt.XXXXXX")
trap 'rm -f "$gofmt_output"' 0 HUP INT TERM
git diff --cached --name-only --diff-filter=ACMR -- '*.go' |
while IFS= read -r f; do
  gofmt -l "$f" >>"$gofmt_output"
done
if [ -s "$gofmt_output" ]; then
  echo "pre-commit: gofmt needed:" >&2
  cat "$gofmt_output" >&2
  echo "fix: gofmt -w <files>" >&2
  exit 1
fi

# --- Secrets in staged content ------------------------------------------
if command -v betterleaks >/dev/null 2>&1; then
  betterleaks git . --pre-commit --staged --no-banner --redact
else
  echo "pre-commit: betterleaks not installed; skipping (CI still scans)" >&2
fi

# --- Internal tooling names in public prose -----------------------------
# Changelogs, docs, and READMEs are published; private tooling (glean, beads)
# must never be referenced there. Code/CI/agent files are exempt.
staged_prose=$(git diff --cached --name-only --diff-filter=ACMR -- \
  'CHANGELOG.md' 'README.md' 'docs/*.md' 'docs/**/*.md')
if [ -n "$staged_prose" ]; then
  hits=$(printf '%s\n' "$staged_prose" |
    while IFS= read -r f; do
      git show ":$f" | grep -inE 'glean|beads' | sed "s|^|$f:|" || true
    done)
  if [ -n "$hits" ]; then
    echo "pre-commit: internal tooling reference in public prose:" >&2
    echo "$hits" >&2
    echo "fix: reword without naming private tools (e.g. 'a triaged audit pass')" >&2
    exit 1
  fi
fi
