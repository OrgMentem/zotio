# The shareable one: a year of reading, from the local store.
Output ../assets/demos/wrapped.gif

Set FontSize 15
Set Width 920
Set Height 560
Set Padding 12
Set TypingSpeed 30ms
Set Shell "bash"
Set Theme "Catppuccin Mocha"

Hide
Type "export PATH=$PWD/../../bin:$PATH ZOTIO_DEMO=1 NO_COLOR=" Enter
Type "clear" Enter
Show

Type "zotio library wrapped --year 2026"
Enter
Sleep 6s
